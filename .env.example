# IDMP web/API URL. The UI can auto-discover common local ports.
# Use the IDMP port ending in 42, not the TSDB REST port ending in 41.
IDMP_URL=http://localhost:6042
IDMP_USER=your-idmp-email@company.com
IDMP_PASSWORD=your-password

# Alternative to email/password:
# IDMP_API_KEY=

# Optional compatibility and deployment settings:
IDMP_AUTO_DISCOVER=1
IDMP_REQUEST_TIMEOUT=30
# IDMP_PUBLIC_URL=http://localhost:7142

UI_HOST=127.0.0.1
UI_PORT=8765
MAX_UPLOAD_MB=100

# Optional: external LLM quality-check agent (post-migrate harness)
# OpenAI-compatible (OpenAI, Azure, OpenRouter, Ollama, LiteLLM, …):
# QA_LLM_PROVIDER=openai
# QA_LLM_API_KEY=sk-...
# QA_LLM_BASE_URL=https://api.openai.com/v1
# QA_LLM_MODEL=gpt-4.1
# Anthropic:
# QA_LLM_PROVIDER=anthropic
# QA_LLM_API_KEY=sk-ant-...
# QA_LLM_MODEL=claude-sonnet-4-5
# QA_PASS_SCORE=75
# Let external LLM co-pilot IDMP's panel AI (1=on when key present):
QA_LLM_ASSIST_PANELS=1
# Richer briefs + series chrome polish (spend more tokens):
QA_LLM_POWER=1
QA_LLM_TIMEOUT=180

# Docker notes:
# - Leave IDMP_URL as localhost; the container translates it to host.docker.internal.
# - If IDMP is in the same Compose network, use its service URL for IDMP_URL and
#   set IDMP_PUBLIC_URL to the host URL users open in a browser.
